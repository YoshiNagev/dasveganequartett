---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/rules.css";

const icons = {
  cards: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="7" y="3" width="12" height="16" rx="2"/><path d="M7 7H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2"/></svg>`,
  categories: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 9 5-9 5-9-5 9-5Z"/><path d="m3 12 9 5 9-5"/><path d="m3 16 9 5 9-5"/></svg>`,
  modes: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><path d="m10.8 6.8-4.6 9.4M13.2 6.8l4.6 9.4M7 18h10"/></svg>`,
  qr: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3h-3zM20 14v3M14 20h3M20 20h.01"/></svg>`,
  eye: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>`,
  book: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 5.5A3.5 3.5 0 0 1 6 2h5v17H6a3.5 3.5 0 0 0-3.5 3.5Z"/><path d="M21.5 5.5A3.5 3.5 0 0 0 18 2h-5v17h5a3.5 3.5 0 0 1 3.5 3.5Z"/></svg>`,
  heart: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.8-8.6a5.5 5.5 0 0 0 0-7.8Z"/></svg>`,
  spiral: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21a9 9 0 1 1 9-9c0 4.1-3.1 7-7.1 7-3.5 0-6-2.2-6-5.3 0-2.8 2-4.8 4.7-4.8 2.3 0 4 1.6 4 3.7 0 1.7-1.2 2.9-2.8 2.9-1.3 0-2.3-.9-2.3-2.1 0-.8.6-1.5 1.4-1.5"/></svg>`,
  burst: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22c4.4 0 8-3.4 8-7.8 0-3.2-1.8-5.5-4.3-7.7.1 2.1-1.1 3.7-2.5 4.4.2-3.6-1.7-6.5-4.7-8.9.2 3.4-1.8 5.7-3.1 7.6A8.1 8.1 0 0 0 4 14.2C4 18.6 7.6 22 12 22Z"/><path d="M9.5 18.5c-1-2.4.3-4.5 2.3-6.2.1 1.7.9 2.8 2.1 3.8.8.7 1 1.6.6 2.4"/></svg>`,
  divert: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 3h5v5"/><path d="m21 3-6.6 6.6a2 2 0 0 1-2.8 0L9.4 7.4a2 2 0 0 0-2.8 0L3 11"/><path d="M16 21h5v-5"/><path d="m21 21-6.6-6.6a2 2 0 0 0-2.8 0l-2.2 2.2a2 2 0 0 1-2.8 0L3 13"/></svg>`,
  dumbbell: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 7v10M3 9v6M18 7v10M21 9v6M6 12h12"/></svg>`,
  chat: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 11.5a8.4 8.4 0 0 1-9 8.5 10 10 0 0 1-4-.8L3 21l1.7-4.2A8 8 0 0 1 3 11.5C3 6.8 7 3 12 3s9 3.8 9 8.5Z"/><path d="M8 12h.01M12 12h.01M16 12h.01"/></svg>`,
  home: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3 11 9-8 9 8"/><path d="M5 10v11h14V10M9 21v-7h6v7"/></svg>`,
  globe: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>`,
};

const stats = [
  { value: "54", label: "Spielkarten", icon: icons.cards, tone: "lavender" },
  { value: "6", label: "Kategorien", icon: icons.categories, tone: "aqua" },
  { value: "3", label: "Spielmodi", icon: icons.modes, tone: "green" },
];

const cardParts = [
  {
    number: "01",
    title: "Kategorie & Kartennummer",
    description:
      "Nützlich zur schnellen Suche auf der Webseite dasveganequartett.de.",
  },
  {
    number: "02",
    title: "Argument",
    description:
      "Eine gängige Formulierung eines der häufigsten Argumente gegen Veganismus.",
  },
  {
    number: "03",
    title: "Bewertungskategorien",
    description:
      "6 Kategorien, in denen die Argumente gemessen werden.",
  },
];

const ratingCategories = [
  {
    number: "01",
    title: "Verbreitung",
    icon: icons.eye,
    tone: "aqua",
    description:
      "Wie häufig hört man dieses Argument in Diskussionen über Veganismus?",
  },
  {
    number: "02",
    title: "Komplexität",
    icon: icons.book,
    tone: "aqua",
    description:
      "Wie ausgiebig muss man sich mit dem Argument beschäftigen, um es widerlegen zu können?",
  },
  {
    number: "03",
    title: "Emotionalität",
    icon: icons.heart,
    tone: "coral",
    description:
      "Wie emotional sind die Nichtveganer, die so argumentieren? Beziehungsweise wie viel hängt ihnen an diesem Argument?",
  },
  {
    number: "04",
    title: "Delulu-Faktor",
    icon: icons.spiral,
    tone: "gold",
    description:
      "Wie realitätsfern muss man sein, um so zu argumentieren?",
  },
  {
    number: "05",
    title: "Ragebait-Faktor",
    icon: icons.burst,
    tone: "lavender",
    description:
      "Wie gerne würden Veganer auf dieses Argument emotional reagieren?",
  },
  {
    number: "06",
    title: "Ablenkungsfaktor",
    icon: icons.divert,
    tone: "green",
    description:
      "Wie viel versucht dieses Argument eigentlich nur, von den Opfern abzulenken?",
  },
];

const modes = [
  {
    number: "1",
    title: "Trumpfen-Quartett",
    players: "2–6 Spieler",
    icon: icons.cards,
    tone: "lavender",
    paragraphs: [
      "Jeder Spieler bekommt Karten, die jüngste Person wählt eine Bewertungskategorie aus. Wer in dieser Kategorie mit seiner Karte den höchsten Wert hat, gewinnt die Karten der anderen. Der Gewinner ist nun am Zug.",
    ],
    counterRule: true,
  },
  {
    number: "2",
    title: "Bootcamp",
    players: "2+ Spieler",
    icon: icons.dumbbell,
    tone: "aqua",
    paragraphs: [
      "Eine Person zieht eine Karte und liest das Argument vor. Die andere Person oder die Gruppe versucht darauf zu antworten und gute Gegeneinwände zu finden.",
      "Wenn man unsicher ist oder neue Antworten trainieren möchte, kann man anschließend den QR-Code auf der Kartenrückseite scannen und im Forum nachschauen, was andere bereits beigetragen haben.",
      "Dieser Modus eignet sich gut, um neuen werdenden Aktivisti die Angst vorm Outreach zu nehmen.",
    ],
  },
  {
    number: "3",
    title: "Ice Breaker",
    players: "2+ Spieler",
    icon: icons.chat,
    tone: "coral",
    paragraphs: [
      "Eine oder mehrere Karten werden zufällig gezogen oder bewusst ausgewählt. Anschließend spricht die Gruppe darüber, warum das Argument interessant wirkt, ob es stark oder schwach erscheint und welche Gedanken oder Erfahrungen damit verbunden sind.",
      "Dieser Modus eignet sich besonders gut für Schulunterricht, Kennenlernrunden, Gruppenabende oder gegebenenfalls sogar für kreativen Outreach, da man hier sehr leicht und auf natürliche Weise ins Gespräch kommt.",
    ],
  },
];
---

<BaseLayout
  title="Spielanleitung"
  description="Spielanleitung für Das Quartett der Argumente: Kartenaufbau, Bewertungskategorien und drei verschiedene Spielmodi."
>
  <main class="rules-page">
    <section class="rules-hero">
      <div class="rules-hero__rays" aria-hidden="true"></div>

      <div class="rules-shell rules-hero__grid">
        <div class="rules-hero__copy">
          <p class="rules-eyebrow">Das Quartett der Argumente</p>
          <h1 class="rules-hero__title">Spielanleitung</h1>
          <p class="rules-hero__intro">
            54 Argumente, sechs Bewertungskategorien und drei verschiedene
            Möglichkeiten, gemeinsam zu spielen, zu lernen und zu diskutieren.
          </p>

          <div class="rules-stats" aria-label="Spielübersicht">
            {stats.map((stat) => (
              <article class={`rules-stat rules-tone--${stat.tone}`}>
                <span class="rules-stat__icon" aria-hidden="true" set:html={stat.icon}></span>
                <div>
                  <strong>{stat.value}</strong>
                  <span>{stat.label}</span>
                </div>
              </article>
            ))}
          </div>

          <div class="rules-scan-note">
            <span class="rules-scan-note__icon" aria-hidden="true" set:html={icons.qr}></span>
            <p>
              Scanne die QR-Codes auf den Karten für mehr Informationen und
              Diskussionen.
            </p>
          </div>
        </div>

        <div class="rules-hero__card">
          <img
            src="/images/cards/card-24.png"
            alt="Beispielkarte 24: Ich kannte mal einen Veganer und der ist gestorben"
            width="635"
            height="889"
          />
          <a href="/cards/24">Beispielargument ansehen <span>→</span></a>
        </div>
      </div>
    </section>

    <section class="rules-section rules-card-guide">
      <div class="rules-shell">
        <header class="rules-section-heading">
          <span></span>
          <h2>So liest du eine Karte</h2>
          <span></span>
        </header>

        <div class="rules-card-guide__grid">
          <div class="rules-card-guide__list">
            {cardParts.map((part) => (
              <article class="rules-card-part">
                <span class="rules-card-part__number">{part.number}</span>
                <div>
                  <h3>{part.title}</h3>
                  <p>{part.description}</p>
                </div>
              </article>
            ))}
          </div>

          <div class="rules-card-guide__image">
            <img
              src="/images/cards/card-24.png"
              alt="Aufbau der Beispielkarte 24"
              loading="lazy"
              width="635"
              height="889"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="rules-section rules-ratings">
      <div class="rules-shell">
        <header class="rules-section-heading">
          <span></span>
          <h2>Was bedeuten die Bewertungskategorien?</h2>
          <span></span>
        </header>

        <div class="rules-ratings__grid">
          {ratingCategories.map((rating) => (
            <article class="rules-rating-card">
              <span class={`rules-rating-card__icon rules-tone-bg--${rating.tone}`} aria-hidden="true" set:html={rating.icon}></span>
              <div>
                <div class="rules-rating-card__title">
                  <span>{rating.number}</span>
                  <h3>{rating.title}</h3>
                </div>
                <p>{rating.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="rules-section rules-modes">
      <div class="rules-shell">
        <header class="rules-section-heading rules-section-heading--stacked">
          <span></span>
          <div>
            <h2>Die 3 Spielmodi</h2>
            <p>Wählt den Modus, der zu eurer Runde passt.</p>
          </div>
          <span></span>
        </header>

        <div class="rules-modes__grid">
          {modes.map((mode) => (
            <article class={`rules-mode-card rules-mode-card--${mode.tone}`}>
              <header class="rules-mode-card__header">
                <span class="rules-mode-card__icon" aria-hidden="true" set:html={mode.icon}></span>
                <div>
                  <p class="rules-mode-card__label">{mode.number}. Modus</p>
                  <h3>{mode.title}</h3>
                  <p>{mode.players}</p>
                </div>
              </header>

              <div class="rules-mode-card__body">
                {mode.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>

              {mode.counterRule && (
                <aside class="rules-counter-rule">
                  <h4>Optionale Variante mit Konterkategorien</h4>
                  <p>
                    Die 6 Hauptkategorien können sich gegenseitig kontern.
                  </p>
                  <p>
                    Beispiel: Die gelbe Kategorie „Philosophische Argumente“
                    kontert die grüne Kategorie „Natur, Kultur & Religion“.
                    Trifft Gelb auf Grün, erhält der gelbe Wert 20 Zusatzpunkte,
                    bevor verglichen wird.
                  </p>
                  <div class="rules-counter-rule__cycle" aria-label="Konterkreislauf">
                    <span class="rules-cycle-dot rules-cycle-dot--gold">1</span><b>→</b>
                    <span class="rules-cycle-dot rules-cycle-dot--green">2</span><b>→</b>
                    <span class="rules-cycle-dot rules-cycle-dot--aqua">3</span><b>→</b>
                    <span class="rules-cycle-dot rules-cycle-dot--lavender">4</span><b>→</b>
                    <span class="rules-cycle-dot rules-cycle-dot--coral">5</span><b>→</b>
                    <span class="rules-cycle-dot rules-cycle-dot--pink">6</span>
                  </div>
                </aside>
              )}
            </article>
          ))}
        </div>

        <div class="rules-bottom-grid">
          <article class="rules-bottom-card">
            <span class="rules-bottom-card__icon" aria-hidden="true" set:html={icons.home}></span>
            <div>
              <h3>Hausregeln willkommen</h3>
              <p>
                Ihr könnt alle Modi frei an eure Runde anpassen oder zusätzliche
                Regeln erfinden.
              </p>
            </div>
          </article>

          <article class="rules-bottom-card">
            <span class="rules-bottom-card__icon rules-bottom-card__icon--green" aria-hidden="true" set:html={icons.globe}></span>
            <div>
              <h3>Mehr Infos und Diskussionen</h3>
              <p>
                Weitere Antworten, Quellen und Diskussionen findet ihr auf den
                einzelnen Argumentseiten.
              </p>
              <a href="/cards">Alle Argumente ansehen <span>→</span></a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
