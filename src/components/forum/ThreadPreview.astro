---
const { thread } = Astro.props;
---

<a class="thread-preview" href={`/forum/thread/${thread.id}`}>
  <div>
    <h3>{thread.title}</h3>
    <p>{thread.excerpt}</p>
  </div>

  <div class="thread-meta">
    <span>{thread.author}</span>
    <span>{thread.replies} Antworten</span>
    <span>{thread.createdAt}</span>
  </div>
</a>