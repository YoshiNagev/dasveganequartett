---
const floatingCards = [
  {
    src: "/images/cards/card-37.png",
    alt: "Philosophische Argumente Karte",
    className: "card-one",
  },
  {
    src: "/images/cards/card-16.png",
    alt: "Natur Kultur Religion Karte",
    className: "card-two",
  },
  {
    src: "/images/cards/card-01.png",
    alt: "Gesundheit Umwelt Nachhaltigkeit Karte",
    className: "card-three",
  },
];
---

<section class="hero-section">
  <div class="hero-content">
    <p class="eyebrow">Das Diskussionskartenspiel</p>

    <h1>Das Vegane Quartett</h1>

    <p class="hero-subtitle">
      54 Argumente gegen Veganismus, als Kartenspiel,
      Diskussionsstarter und interaktive Plattform.
    </p>

    <div class="hero-actions">
      <a href="/preorder" class="btn btn-primary btn-md">
        Jetzt vorbestellen
      </a>

      <a href="/cards" class="btn btn-secondary btn-md">
        Argumente ansehen
      </a>
    </div>
  </div>

  <div class="hero-card-stage" aria-hidden="true">
    {floatingCards.map((card) => (
      <div class={`hero-card-frame ${card.className}`}>
        <img
          src={card.src}
          alt={card.alt}
          loading="eager"
          draggable="false"
        />
      </div>
    ))}
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - 86px);
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 3rem;
    align-items: center;
    padding: 3.5rem clamp(0.25rem, 4vw, 3rem) 4rem;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    align-self: center;
  }

  .hero-content h1 {
    font-size: clamp(4rem, 8vw, 7.4rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
    margin: 0;
    max-width: 8ch;
  }

  .hero-subtitle {
    max-width: 620px;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--muted-text);
    margin: 1.5rem 0 2rem;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-card-stage {
    position: relative;
    height: min(72vh, 760px);
    min-height: 610px;
    align-self: center;
  }

  .hero-card-frame {
    position: absolute;
    aspect-ratio: 635 / 889;
    width: clamp(220px, 20vw, 330px);
    border-radius: 22px;
    padding: 0;
    background: transparent;
    box-shadow:
      0 34px 90px rgba(0, 0, 0, 0.48),
      0 0 50px rgba(126, 255, 203, 0.08);
    overflow: hidden;
    animation: card-float 8s ease-in-out infinite;
    transform-origin: center;
  }

  .hero-card-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    display: block;
  }

  .card-one {
    top: 3%;
    left: 18%;
    z-index: 1;
    --rotation: -10deg;
    animation-delay: 0s;
  }

  .card-two {
    top: 18%;
    right: 5%;
    z-index: 2;
    --rotation: 8deg;
    animation-delay: -1.5s;
  }

  .card-three {
    bottom: 0;
    left: 34%;
    z-index: 3;
    --rotation: -2deg;
    animation-delay: -3s;
  }

  @keyframes card-float {
    0%,
    100% {
      transform: translateY(0) rotate(var(--rotation));
    }

    50% {
      transform: translateY(-18px) rotate(var(--rotation));
    }
  }

  @media (max-width: 1000px) {
    .hero-section {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 4rem;
    }

    .hero-content {
      text-align: center;
    }

    .hero-content h1 {
      margin-inline: auto;
    }

    .hero-subtitle {
      margin-inline: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-card-stage {
      height: 620px;
      min-height: 620px;
    }

    .hero-card-frame {
      width: clamp(190px, 32vw, 280px);
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-top: 3rem;
    }

    .hero-card-stage {
      height: 500px;
      min-height: 500px;
    }

    .hero-card-frame {
      width: 190px;
      padding: 0;
      border-radius: 18px;
    }

    .hero-card-frame img {
      border-radius: inherit;
    }

    .card-one {
      left: 0;
      top: 0;
    }

    .card-two {
      right: 0;
      top: 4rem;
    }

    .card-three {
      left: 26%;
      bottom: 0;
    }
  }
</style>